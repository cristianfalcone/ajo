{
	"name": "ajo",
	"version": "0.1.33",
	"description": "ajo is a JavaScript view library for building user interfaces",
	"type": "module",
	"types": "./types.ts",
	"module": "./dist/index.js",
	"exports": {
		".": {
			"react-native": "./index.js",
			"types": "./types.ts",
			"import": "./dist/index.js"
		},
		"./context": {
			"react-native": "./context.js",
			"types": "./types.ts",
			"import": "./dist/context.js"
		},
		"./html": {
			"types": "./types.ts",
			"import": "./dist/html.js"
		},
		"./jsx-runtime": {
			"react-native": "./jsx.js",
			"types": "./types.ts",
			"import": "./dist/jsx.js"
		},
		"./jsx-dev-runtime": {
			"react-native": "./jsx.js",
			"types": "./types.ts",
			"import": "./dist/jsx.js"
		}
	},
	"files": [
		"dist",
		"context.js",
		"html.js",
		"index.js",
		"jsx.js",
		"LLMs.md",
		"types.ts"
	],
	"scripts": {
		"test": "vitest --run",
		"bench": "pnpm --dir bench bench",
		"bench:quick": "pnpm --dir bench bench:quick",
		"bench:ajo": "pnpm --dir bench bench:ajo",
		"build": "vite build",
		"bump": "pnpm version patch && git push && git push --tags",
		"release": "pnpm test && pnpm build && pnpm bump && pnpm publish"
	},
	"devDependencies": {
		"@types/node": "26.0.0",
		"happy-dom": "20.10.6",
		"terser": "5.48.0",
		"typescript": "6.0.3",
		"vite": "8.0.16",
		"vitest": "4.1.9"
	},
	"keywords": [
		"ui",
		"frontend",
		"web",
		"dom",
		"jsx"
	],
	"repository": "cristianfalcone/ajo",
	"author": "Cristian Falcone",
	"license": "ISC",
	"bugs": "https://github.com/cristianfalcone/ajo/issues",
	"homepage": "https://github.com/cristianfalcone/ajo#readme"
}
